# =============================================================================
# Banking Assistant — .gitignore
# =============================================================================

# ── Secrets & deployment outputs (NEVER commit these) ────────────────────────
# Contains real AWS account IDs, ARNs, API Gateway IDs, and endpoints
deploy/outputs.env

# Contains real AWS account ID, ARNs, ECR repo, CodeBuild project, memory IDs
.bedrock_agentcore.yaml

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
pip-wheel-metadata/
MANIFEST

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env
.env.*
!.env.example

# ── Testing & coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.hypothesis/
*.cover
nosetests.xml
coverage.xml

# ── Type checking & linting ───────────────────────────────────────────────────
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json

# ── Lambda build artifacts ────────────────────────────────────────────────────
/tmp/*.zip
*.zip

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
.kiro/
*.swp
*.swo
*~

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── AWS / CDK / Terraform ─────────────────────────────────────────────────────
cdk.out/
.cdk.staging/
*.tfstate
*.tfstate.*
.terraform/

# ── Docker ────────────────────────────────────────────────────────────────────
# Keep .dockerignore and Dockerfile tracked
# Exclude local Docker volumes
.docker/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── uv ────────────────────────────────────────────────────────────────────────
.uv/
uv.lock
