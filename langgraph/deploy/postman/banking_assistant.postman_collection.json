{
  "info": {
    "name": "Banking Assistant — AgentCore API",
    "_postman_id": "banking-assistant-agentcore-v1",
    "description": "Test the Banking Assistant deployed on AWS Bedrock AgentCore Runtime via API Gateway.\n\n## Setup\n1. Set the `base_url` collection variable to your API Gateway endpoint.\n   Example: `https://abc123.execute-api.us-east-2.amazonaws.com`\n2. Run the requests in order or individually.\n\n## Architecture\nPostman → API Gateway → api-gateway-invoker Lambda → AgentCore Runtime → LangGraph Agent → Tool Lambdas",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://bbcwr3ugt1.execute-api.us-east-2.amazonaws.com",
      "description": "API Gateway endpoint URL (no trailing slash). Update this after deployment."
    },
    {
      "key": "session_id",
      "value": "",
      "description": "Session ID for multi-turn conversations. Auto-populated by the first request."
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "GET /health (not available on prod — use POST /)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Note: The production API Gateway only exposes POST /. This request is for reference — use the local_server.py for health checks during development."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Account Balance Queries",
      "item": [
        {
          "name": "Get Balance — ACC001 (Alice, below minimum)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has response field', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('response');",
                  "    pm.expect(body.response).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.test('Has session_id', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('session_id');",
                  "    pm.collectionVariables.set('session_id', body.session_id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"prompt\": \"What is the current balance for account ACC001?\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
            },
            "description": "ACC001 (Alice Johnson) has $1,200.50 balance but requires $2,500 minimum for Premium Checking. Expect penalty warning."
          },
          "response": [
            {
              "name": "Expected Response",
              "originalRequest": {
                "method": "POST",
                "header": [{"key": "Content-Type", "value": "application/json"}],
                "body": {
                  "mode": "raw",
                  "raw": "{\"prompt\": \"What is the current balance for account ACC001?\"}"
                },
                "url": {"raw": "{{base_url}}/", "host": ["{{base_url}}"], "path": [""]}
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n    \"response\": \"The current balance for account ACC001 is $1,200.50 USD. This is a Premium Checking account with a minimum balance requirement of $2,500.00. The account is currently BELOW the minimum balance. A monthly penalty fee of $25.00 will be applied.\",\n    \"session_id\": \"a1b2c3d4-...\",\n    \"agent_runtime_arn\": \"arn:aws:bedrock-agentcore:us-east-2:...\",\n    \"mode\": \"aws_bedrock_agentcore\"\n}"
            }
          ]
        },
        {
          "name": "Get Balance — ACC002 (Bob, compliant)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has response field', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('response');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"prompt\": \"What is the balance for ACC002 and is there any penalty?\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
            },
            "description": "ACC002 (Bob Smith) has $820.00 balance, minimum is $500. Should be compliant — no penalty."
          },
          "response": []
        },
        {
          "name": "Get Balance — ACC003 (Carol, Savings)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"prompt\": \"Check the balance and minimum balance requirement for account ACC003\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
            },
            "description": "ACC003 (Carol White) has $1,100.50 in Savings, minimum is $300. Compliant."
          },
          "response": []
        }
      ]
    },
    {
