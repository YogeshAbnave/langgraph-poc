    },
    {
      "name": "Multi-Turn Conversation",
      "item": [
        {
          "name": "Turn 1 — Ask about ACC001",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('session_id', body.session_id);",
                  "console.log('Session ID saved:', body.session_id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"prompt\": \"What is the balance for ACC001?\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
            },
            "description": "First turn — saves session_id for follow-up."
          },
          "response": []
        },
        {
          "name": "Turn 2 — Follow-up (same session)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"prompt\": \"Now show me the owner details for that same account\",\n    \"session_id\": \"{{session_id}}\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
            },
            "description": "Second turn using the same session_id from Turn 1."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Error Cases",
      "item": [
        {
          "name": "Invalid Account ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 (agent handles gracefully)', () => pm.response.to.have.status(200));",
                  "pm.test('Response mentions not found', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.response.toLowerCase()).to.satisfy(",
                  "        s => s.includes('not found') || s.includes('invalid') || s.includes('unable')",
                  "    );",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"prompt\": \"What is the balance for account ACC999?\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
            },
            "description": "ACC999 does not exist. The agent should return a graceful error message."
          },
          "response": []
        },
        {
          "name": "Empty Prompt",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('Has error field', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('error');",
