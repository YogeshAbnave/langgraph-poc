    {
      "name": "Combined Queries",
      "item": [
        {
          "name": "Balance + Details — ACC001",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response is comprehensive', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.response.length).to.be.greaterThan(50);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"prompt\": \"Give me a full account summary for ACC001: balance, compliance status, and owner information\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
