            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"prompt\": \"Which accounts are at risk of penalty fees? Check ACC001, ACC002, and ACC003\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
            },
            "description": "Multi-account compliance check. The agent will call get_account_balance for each account."
          },
          "response": []
